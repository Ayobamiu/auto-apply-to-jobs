{
  "manifest_version": 3,
  "name": "Handshake session to app",
  "version": "1.0.0",
  "description": "Send Handshake cookies to the auto-apply backend",
  "permissions": ["cookies", "storage"],
  "host_permissions": [
    "*://*.joinhandshake.com/*",
    "*://localhost/*",
    "*://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send Handshake session"
  },
  "background": {
    "service_worker": "background.js"
  }
}
