{
  "manifest_version": 3,
  "name": "Handshake Sync Pro",
  "version": "1.0.0",
  "description": "Automatically syncs your Handshake sessions with MeritHQ.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["cookies", "storage", "tabs", "scripting"],
  "host_permissions": [
    "*://*.joinhandshake.com/*",
    "https://merithq.io/*",
    "https://www.merithq.io/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://merithq.io/*", "https://www.merithq.io/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
