{
  "manifest_version": 3,
  "name": "Handshake Auto-Sync",
  "version": "1.1.0",
  "description": "Automatically syncs Handshake sessions to auto-apply job automation dashboard.",
  "permissions": ["cookies", "storage", "tabs", "scripting"],
  "host_permissions": [
    "*://*.joinhandshake.com/*",
    "<all_urls>",
    "http://localhost/*",
    "*://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*"],
      "js": ["content.js"]
    }
  ]
}
