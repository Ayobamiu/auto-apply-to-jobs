{
  "name": "playwright-form-demo",
  "version": "1.0.0",
  "description": "Demo project to test a Playwright form-filling bot",
  "type": "module",
  "scripts": {
    "start": "tsx server.ts",
    "bot": "tsx fill-form.ts",
    "test": "node --import tsx --import ./test/setup.ts --test --test-concurrency 1 'test/**/*.test.ts'",
    "test:legacy": "tsx test-form-fill.ts",
    "handshake": "tsx handshake-apply.ts",
    "test:handshake": "tsx test-handshake.ts",
    "handshake:login": "tsx agents/auto_apply_agent/handshake-login.ts",
    "handshake:login:record": "tsx agents/auto_apply_agent/handshake-login-record.ts",
    "handshake:apply": "tsx agents/auto_apply_agent/handshake-apply-real.ts",
    "job:scrape": "tsx agents/job_scraper_agent/index.ts",
    "job:status": "tsx agents/job_scraper_agent/index.ts --status",
    "resume:generate": "tsx agents/resume_generator_agent/index.ts",
    "resume:edit": "tsx agents/resume_generator_agent/resume-edit-cli.ts",
    "pipeline": "tsx orchestration/run-pipeline.ts",
    "api": "nodemon --exec tsx api/server.ts --watch api --watch shared --watch orchestration --watch agents --watch data --ext ts",
    "api:start": "tsx api/server.ts",
    "typecheck": "tsc --noEmit",
    "install-browsers": "playwright install chromium --with-deps && npx camoufox-js fetch"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "jsonresume-theme-even": "^0.26.1",
    "nodemon": "^3.1.0",
    "puppeteer": "^24.37.3",
    "resumed": "^6.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "bcrypt": "^6.0.0",
    "camoufox-js": "^0.9.1",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "moment": "^2.30.1",
    "multer": "^2.1.0",
    "openai": "^6.22.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.18.0",
    "playwright": "^1.49.0",
    "stripe": "^20.4.1",
    "turndown": "^7.2.2"
  }
}
