{
  "name": "playwright-form-demo",
  "version": "1.0.0",
  "description": "Demo project to test a Playwright form-filling bot",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "bot": "node fill-form.js",
    "test": "node test-form-fill.js",
    "handshake": "node handshake-apply.js",
    "test:handshake": "node test-handshake.js",
    "handshake:login": "node agents/auto_apply_agent/handshake-login.js",
    "handshake:login:record": "node agents/auto_apply_agent/handshake-login-record.js",
    "handshake:apply": "node agents/auto_apply_agent/handshake-apply-real.js",
    "resume:generate": "node agents/resume_generator_agent/index.js",
    "pipeline": "node orchestration/run-pipeline.js"
  },
  "devDependencies": {
    "jsonresume-theme-even": "^0.26.1",
    "playwright": "^1.49.0",
    "puppeteer": "^24.37.3",
    "resumed": "^6.1.0"
  }
}
