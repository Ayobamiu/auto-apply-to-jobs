{
  "name": "playwright-form-demo",
  "version": "1.0.0",
  "description": "Demo project to test a Playwright form-filling bot",
  "type": "module",
  "scripts": {
    "start": "tsx server.ts",
    "bot": "tsx fill-form.ts",
    "test": "tsx test-form-fill.ts",
    "handshake": "tsx handshake-apply.ts",
    "test:handshake": "tsx test-handshake.ts",
    "handshake:login": "tsx agents/auto_apply_agent/handshake-login.ts",
    "handshake:login:record": "tsx agents/auto_apply_agent/handshake-login-record.ts",
    "handshake:apply": "tsx agents/auto_apply_agent/handshake-apply-real.ts",
    "job:scrape": "tsx agents/job_scraper_agent/index.ts",
    "job:status": "tsx agents/job_scraper_agent/index.ts --status",
    "resume:generate": "tsx agents/resume_generator_agent/index.ts",
    "resume:edit": "tsx agents/resume_generator_agent/resume-edit-cli.ts",
    "pipeline": "tsx orchestration/run-pipeline.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "jsonresume-theme-even": "^0.26.1",
    "playwright": "^1.49.0",
    "puppeteer": "^24.37.3",
    "resumed": "^6.1.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "openai": "^6.22.0",
    "turndown": "^7.2.2"
  }
}