{
  "name": "auto-apply-to-jobs",
  "version": "1.0.0",
  "private": true,
  "description": "Root workspace; run scripts via backend.",
  "scripts": {
    "api": "cd backend && npm run api",
    "typecheck": "cd backend && npm run typecheck",
    "pipeline": "cd backend && npm run pipeline",
    "handshake:apply": "cd backend && npm run handshake:apply",
    "handshake:login": "cd backend && npm run handshake:login",
    "handshake:login:record": "cd backend && npm run handshake:login:record",
    "job:scrape": "cd backend && npm run job:scrape",
    "job:status": "cd backend && npm run job:status",
    "resume:generate": "cd backend && npm run resume:generate",
    "resume:edit": "cd backend && npm run resume:edit",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "dev": "cd frontend && npm run build && cd ../backend && npm run api"
  },
  "dependencies": {
    "dayjs": "^1.11.19"
  }
}
